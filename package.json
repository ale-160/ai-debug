{
  "name": "ai-debug",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --filter @ai-debug/web dev",
    "build": "pnpm --filter @ai-debug/web build",
    "lint": "pnpm --filter @ai-debug/web lint",
    "type-check": "pnpm --filter @ai-debug/web exec tsc --noEmit",
    "analyze": "pnpm --filter @ai-debug/web analyze",
    "clean": "pnpm --filter @ai-debug/web clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --filter @ai-debug/web exec vitest run",
    "push:feature": "node scripts/push-feature.mjs"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  }
}
