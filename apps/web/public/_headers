# Cloudflare Pages 缓存策略
# Next.js 静态导出会把 public/_headers 复制到 out/，部署后由 Cloudflare 边缘节点读取

# 构建产物（含 hash 文件名）—— 长缓存 + immutable
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# HTML —— 边缘缓存 1 小时 + 后台异步更新
# s-maxage 让 Cloudflare CDN 缓存，stale-while-revalidate 让用户立即拿到旧缓存同时后台刷新
# max-age=0 保留：浏览器仍每次校验，确保用户拿到最新 HTML
/*
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400

# 静态图片资源
/*.png
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400
/*.ico
  Cache-Control: public, max-age=86400
/*.webp
  Cache-Control: public, max-age=86400
